{
  "info": {
    "name": "SOS Mascotas Chile API",
    "description": "Pruebas de endpoints para Auth y Reports.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"nombre\": \"Usuario de Prueba\",\r\n  \"email\": \"prueba@correo.com\",\r\n  \"password\": \"123456\",\r\n  \"telefono\": \"+56912345678\"\r\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.environment.set(\"token\", jsonData.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"email\": \"prueba@correo.com\",\r\n  \"password\": \"123456\"\r\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "Validate Token",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/validate",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "validate"
              ]
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/me",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "me"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Reports",
      "item": [
        {
          "name": "List Reports",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/reports",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "reports"
              ],
              "query": [
                {
                  "key": "tipo",
                  "value": "ANIMAL_PERDIDO",
                  "disabled": true
                },
                {
                  "key": "q",
                  "value": "perro",
                  "disabled": true
                }
              ]
            }
          }
        },
        {
          "name": "Get Report By ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/reports/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "reports",
                "1"
              ]
            }
          }
        },
        {
          "name": "Create Report",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"titulo\": \"Perrito perdido en plaza\",\r\n  \"descripcion\": \"Perrito negro, tamaño mediano, con collar rojo.\",\r\n  \"ubicacion\": \"Plaza de Armas\",\r\n  \"tipo\": \"ANIMAL_PERDIDO\",\r\n  \"fotoUrl\": \"https://ejemplo.com/foto.jpg\"\r\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/reports",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "reports"
              ]
            }
          }
        },
        {
          "name": "Update Report Status",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/reports/1/estado?estado=ENCONTRADO",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "reports",
                "1",
                "estado"
              ],
              "query": [
                {
                  "key": "estado",
                  "value": "ENCONTRADO"
                }
              ]
            }
          }
        },
        {
          "name": "Delete Report",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/reports/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "reports",
                "1"
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:9000"
    }
  ]
}